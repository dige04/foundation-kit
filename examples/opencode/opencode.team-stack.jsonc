{
  "$schema": "https://opencode.ai/config.json",

  // Full optional team-stack example.
  // This keeps the same OpenCode + Hive + Beads model, while showing where
  // Linear, NotebookLM, and Tilth MCP servers can plug in.
  // Replace or remove any MCP entry your team does not use.
  "plugin": ["opencode-hive"],

  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "notebooklm": {
      "type": "local",
      "command": ["npx", "-y", "notebooklm-mcp@latest"]
    },
    "tilth": {
      "type": "local",
      "command": ["tilth", "--mcp"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    }
  },

  "agent": {
    "planner": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      },
      "permission": {
        "bash": {
          "git status": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "bd *": "allow",
          "*": "deny"
        }
      }
    },
    "researcher": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "docs-manager": {
      "temperature": 0.2,
      "permission": {
        "write": {
          "docs/**/*.md": "allow",
          "pods/**/*.md": "allow",
          "*.md": "allow",
          "*": "deny"
        }
      }
    },
    "integration": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "reviewer": {
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    }
  }
}
